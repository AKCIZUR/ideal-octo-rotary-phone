---
const {
  eyebrow = 'VCCSD Docs',
  title,
  lead,
  primaryHref = '/guides/getting-started/',
  primaryLabel = 'Get started',
  secondaryHref = '/guides/deploy/',
  secondaryLabel = 'Deployment',
} = Astro.props;
---

<section class="hero-shell">
  <div class="eyebrow">{eyebrow}</div>
  <h1>{title}</h1>
  <p class="lead">{lead}</p>

  <div class="hero-actions">
    <a class="primary" href={primaryHref}>{primaryLabel}</a>
    <a href={secondaryHref}>{secondaryLabel}</a>
  </div>

  <div class="hero-stat-row">
    <div class="hero-stat">
      <strong>Astro 7</strong>
      <span>Node 22.12+ ready</span>
    </div>
    <div class="hero-stat">
      <strong>Starlight</strong>
      <span>Docs-first UX</span>
    </div>
    <div class="hero-stat">
      <strong>pnpm</strong>
      <span>Locked workflow</span>
    </div>
    <div class="hero-stat">
      <strong>Pages</strong>
      <span>Auto deploy</span>
    </div>
  </div>
</section>
